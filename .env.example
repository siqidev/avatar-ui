# --- API ---
# xAI APIキー（https://console.x.ai/）
XAI_API_KEY=your-xai-api-key
# 長期記憶用（Collections API）
XAI_MANAGEMENT_API_KEY=
XAI_COLLECTION_ID=

# --- アイデンティティ ---
# アバター名（デフォルト: Avatar）
AVATAR_NAME=
# ユーザー名（デフォルト: User）
USER_NAME=

# --- パス ---
# AIの生活空間（デフォルト: ~/Avatar/space）。明示設定時は存在チェックあり
AVATAR_SPACE=

# --- Roblox連携（API_KEY + UNIVERSE_ID の両方設定で有効化） ---
# Open Cloud APIキー（https://create.roblox.com/credentials）
ROBLOX_API_KEY=
# Universe ID（ゲーム設定ページで確認）
ROBLOX_UNIVERSE_ID=
# 観測サーバー認証トークン（Roblox側Config.luauのobservationSecretと一致させる）
ROBLOX_OBSERVATION_SECRET=
# オーナー表示名（観測イベントのフォーマットに使用）
ROBLOX_OWNER_DISPLAY_NAME=
# オーナーのRoblox UserID（数値。オーナー判定に使用。未設定時は全員external扱い）
ROBLOX_OWNER_USER_ID=
# 観測サーバーポート（デフォルト: 3000）
ROBLOX_OBSERVATION_PORT=

# --- X連携（5トークン + USER_ID の全設定で有効化） ---
# OAuth 1.0a認証（https://developer.x.com/）
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Webhook署名検証シークレット
X_WEBHOOK_SECRET=
# 自分のXユーザーID（自己投稿フィルタ用）
X_USER_ID=
# オーナーのXユーザーID（数値。オーナー判定に使用。未設定時は全員external扱い）
X_OWNER_USER_ID=
# Webhookサーバーポート（デフォルト: 3001）
X_WEBHOOK_PORT=
# --- セッションWebSocket ---
# WebSocketサーバーポート（デフォルト: 3002）
SESSION_WS_PORT=
# WebSocket認証トークン（設定時、接続にtoken認証が必要。未設定時は認証なし）
SESSION_WS_TOKEN=

# --- Discord連携（BOT_TOKEN + CHANNEL_ID の両方設定で有効化） ---
# Discordボットトークン
DISCORD_BOT_TOKEN=
# 接続先チャンネルID
DISCORD_CHANNEL_ID=
# オーナーのDiscordユーザーID（数値。オーナー判定に使用。未設定時は全員external扱い）
DISCORD_OWNER_ID=

# --- インフラ ---
# Cloudflareトンネルトークン（設定時、Electronがcloudflaredを自動管理）
CLOUDFLARED_TOKEN=
# Pulse cron式（UTC, デフォルト: 0 6 * * * = JST 15:00, 1日1回）
PULSE_CRON=
# XPulse cron式（UTC, X投稿用、デフォルト: 0 5,9 * * * = JST 14:00/18:00）
XPULSE_CRON=
# ターミナルシェル（デフォルト: OSのデフォルトシェル。macOS=zsh, Linux=bash）
TERMINAL_SHELL=
# AIのシェル実行権限（on / off, デフォルト: off）
# on: AIがターミナルで任意のコマンドを実行できる。リスクを理解した上で有効化すること
AVATAR_SHELL=
# ツール自動承認リスト（カンマ区切り, デフォルト: save_memory,fs_list,fs_read）
# リスト外のツールは実行前にユーザー承認が必要
TOOL_AUTO_APPROVE=

# --- 開発者向け ---
# 開発者モード（on / off, デフォルト: off）
# on: 詳細ログ + ソースタグ表示 + Roblox Monitor全表示
DEV_MODE=
