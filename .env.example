# ============================================================
# Avatar UI 環境変数
# ============================================================
# 必須: XAI_API_KEY のみ。他は全てオプション。
# 各連携は必要なキーが揃った時点で自動有効化される。

# --- API（必須） ---
# xAI APIキー（https://console.x.ai/）
XAI_API_KEY=your-xai-api-key

# 長期記憶用 Collections API（両方設定で有効化）
XAI_MANAGEMENT_API_KEY=
XAI_COLLECTION_ID=

# --- アバター ---
# 名前（デフォルト: Avatar / User）
AVATAR_NAME=
USER_NAME=

# アバター設定ディレクトリ（デフォルト: プロジェクトルート）
# このディレクトリ配下に以下を配置する:
#   BEING.md   — アイデンティティ定義
#   pulse/     — cronタスク（各.mdファイルが1タスク。詳細はdocs/architecture.md）
# デフォルト: プロジェクトルート直下の BEING.md, pulse/ を参照
AVATAR_DIR=

# AIの生活空間（デフォルト: ~/Avatar/space）
# 起動時にrefs/が自動作成される。外部リポ参照: ln -s /path/to/repo refs/name
AVATAR_SPACE=

# --- Roblox連携（API_KEY + UNIVERSE_ID の両方設定で有効化） ---
# Open Cloud APIキー（https://create.roblox.com/credentials）
ROBLOX_API_KEY=
# Universe ID（ゲーム設定ページで確認）
ROBLOX_UNIVERSE_ID=
# 観測サーバー認証トークン（Roblox側Config.luauのobservationSecretと一致させる）
ROBLOX_OBSERVATION_SECRET=
# オーナー表示名（観測イベントのフォーマットに使用）
ROBLOX_OWNER_DISPLAY_NAME=
# オーナーのRoblox UserID（数値。未設定時は全員external扱い）
ROBLOX_OWNER_USER_ID=
# 観測サーバーポート（デフォルト: 3000）
ROBLOX_OBSERVATION_PORT=

# --- X連携（5トークン + USER_ID の全設定で有効化） ---
# OAuth 1.0a認証（https://developer.x.com/）
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Webhook署名検証シークレット
X_WEBHOOK_SECRET=
# 自分のXユーザーID（自己投稿フィルタ用）
X_USER_ID=
# オーナーのXユーザーID（数値。未設定時は全員external扱い）
X_OWNER_USER_ID=
# Webhookサーバーポート（デフォルト: 3001）
X_WEBHOOK_PORT=

# --- Discord連携（BOT_TOKEN + CHANNEL_ID の両方設定で有効化） ---
# Discordボットトークン（https://discord.com/developers/）
DISCORD_BOT_TOKEN=
# テキストチャンネルID
DISCORD_CHANNEL_ID=
# オーナーのDiscordユーザーID（数値。未設定時は全員external扱い）
DISCORD_OWNER_ID=

# --- ネットワーク ---
# セッションWebSocket（Console UI・Discord窓口が接続。デフォルト: 3002）
SESSION_WS_PORT=
# WebSocket認証トークン（設定時のみtoken認証。デフォルト: 認証なし）
SESSION_WS_TOKEN=
# Cloudflareトンネルトークン（設定時、cloudflaredを自動管理）
CLOUDFLARED_TOKEN=

# --- 権限 ---
# AIのシェル実行権限（on/off, デフォルト: off）
# on: AIがターミナルで任意のコマンドを実行できる
AVATAR_SHELL=
# ツール自動承認リスト（カンマ区切り, デフォルト: save_memory,fs_list,fs_read）
# リスト外のツールは実行前にユーザー承認が必要
TOOL_AUTO_APPROVE=

# --- システム ---
# ターミナルシェル（デフォルト: OSのデフォルトシェル。macOS=zsh, Linux=bash, Windows=powershell）
TERMINAL_SHELL=
# 開発者モード（on/off, デフォルト: off。on: 詳細ログ + Roblox Monitor全表示）
DEV_MODE=
