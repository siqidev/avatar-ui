{
  "name": "avatar-ui",
  "productName": "AUI",
  "version": "0.5.1",
  "description": "AUI reference implementation",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite build && tsx src/headless/index.ts",
    "start:electron": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "headless": "tsx src/headless/index.ts"
  },
  "author": "siqidev",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "out/main/index.js",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "openai": "^6.22.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "undici": ">=6.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.6.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
